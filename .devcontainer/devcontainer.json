{
  "name": "sigma-prototype",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "remoteUser": "node",
  "workspaceFolder": "/workspaces/sigma-prototype",
  "forwardPorts": [5173, 8787, 8788, 8789, 8790],
  "portsAttributes": {
    "5173": { "label": "web (SvelteKit dev)" },
    "8787": { "label": "api (wrangler dev)" },
    "8788": { "label": "assistant (wrangler dev)" },
    "8789": { "label": "etl (wrangler dev)" },
    "8790": { "label": "admin (wrangler dev)" }
  },
  "otherPortsAttributes": { "onAutoForward": "notify" },
  "mounts": [
    "source=sigma-prototype-node-modules,target=/workspaces/sigma-prototype/node_modules,type=volume",
    "source=sigma-prototype-pnpm-store,target=/home/node/.pnpm-store,type=volume",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind"
  ],
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "svelte.svelte-vscode",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "EditorConfig.EditorConfig",
        "redhat.vscode-yaml",
        "qwtel.sqlite-viewer",
        "cloudflare.vscode-cloudflare-workers",
        "anthropic.claude-code",
        "github.vscode-github-actions",
        "sanjulaganepola.github-local-actions",
        "bierner.markdown-mermaid",
        "mechatroner.rainbow-csv"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[svelte]": { "editor.defaultFormatter": "svelte.svelte-vscode" },
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  }
}
